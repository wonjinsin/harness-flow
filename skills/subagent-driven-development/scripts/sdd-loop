#!/usr/bin/env node
"use strict";

// sdd-loop — deterministic external executor for an approved implementation
// plan. Each Task Group runs as a fresh headless `claude -p` session; group
// ordering, commit verification, retry caps, and the final-review cycle cap
// live in this script, not in an LLM's discipline. See the design spec:
// docs/harness-flow/specs/2026-07-18-sdd-external-loop-design.md

const fs = require("node:fs");
const path = require("node:path");
const { spawnSync } = require("node:child_process");
const lib = require("./lib/loop-lib.js");

const SCRIPT_DIR = __dirname;
const SKILL_DIR = path.resolve(SCRIPT_DIR, "..");
const REVIEW_TEMPLATE = path.resolve(
  SKILL_DIR,
  "../requesting-code-review/code-reviewer.md"
);
const VERIFY_FIX_TEMPLATE = path.join(SKILL_DIR, "task-reviewer-prompt.md");
const CLAUDE_TIMEOUT_MS = 30 * 60 * 1000;
const MAX_BUFFER = 32 * 1024 * 1024;

function usage() {
  console.log(
    "usage: sdd-loop PLAN_FILE [--model TIER] [--review-model TIER]\n" +
      "                [--permission-mode MODE] [--resume] [--dry-run]\n" +
      "exit codes: 0 complete, 1 error, 2 human intervention needed"
  );
}

function parseArgs(argv) {
  const opts = {
    plan: null,
    model: "sonnet",
    reviewModel: "opus",
    permissionMode: "acceptEdits",
    resume: false,
    dryRun: false,
  };
  for (let i = 0; i < argv.length; i++) {
    const a = argv[i];
    if (a === "--model") opts.model = argv[++i];
    else if (a === "--review-model") opts.reviewModel = argv[++i];
    else if (a === "--permission-mode") opts.permissionMode = argv[++i];
    else if (a === "--resume") opts.resume = true;
    else if (a === "--dry-run") opts.dryRun = true;
    else if (a === "--help" || a === "-h") return { help: true };
    else if (!opts.plan && !a.startsWith("--")) opts.plan = a;
    else return { error: `unknown argument: ${a}` };
  }
  if (!opts.plan) return { error: "PLAN_FILE is required" };
  return opts;
}

function sh(cmd, args, opts) {
  return spawnSync(cmd, args, {
    encoding: "utf8",
    maxBuffer: MAX_BUFFER,
    ...opts,
  });
}

function git(root, ...args) {
  const r = sh("git", args, { cwd: root });
  if (r.status !== 0) {
    throw new Error(`git ${args.join(" ")} failed: ${(r.stderr || "").trim()}`);
  }
  return r.stdout.trim();
}

function die(msg, code) {
  console.error(`sdd-loop: ${msg}`);
  process.exit(code);
}

function saveState(statePath, state) {
  fs.writeFileSync(statePath, JSON.stringify(state, null, 2) + "\n");
}

function appendLedger(ctx, line) {
  fs.appendFileSync(path.join(ctx.workspace, "progress.md"), line + "\n");
}

function appendMetrics(ctx, entry) {
  fs.appendFileSync(
    path.join(ctx.workspace, "loop-metrics.jsonl"),
    JSON.stringify(entry) + "\n"
  );
}

function runClaude(ctx, { phase, model, prompt }) {
  const t0 = Date.now();
  const r = sh(
    "claude",
    [
      "-p",
      "--model",
      model,
      "--permission-mode",
      ctx.opts.permissionMode,
      "--allowedTools",
      "Bash",
      "--output-format",
      "json",
      prompt,
    ],
    { cwd: ctx.root, timeout: CLAUDE_TIMEOUT_MS }
  );
  const wallMs = Date.now() - t0;
  if (r.error && r.error.code === "ENOENT") {
    die("`claude` CLI not found on PATH", 1);
  }
  const parsed = lib.parseClaudeJson(r.stdout || "");
  appendMetrics(ctx, {
    phase,
    model,
    wallMs,
    durationMs: parsed.durationMs,
    usage: parsed.usage,
    costUsd: parsed.costUsd,
    exitCode: r.status,
  });
  return { proc: r, parsed };
}

function runScript(ctx, script, args) {
  const r = sh(path.join(SCRIPT_DIR, script), args, { cwd: ctx.root });
  if (r.status !== 0) {
    throw new Error(`${script} failed: ${(r.stderr || "").trim()}`);
  }
  return r.stdout.trim();
}

function briefPath(ctx, n) {
  return path.join(ctx.workspace, `group-${n}-brief.md`);
}

function reportPath(ctx, n) {
  return path.join(ctx.workspace, `group-${n}-report.md`);
}

function runGroups(ctx) {
  const { state } = ctx;
  let group;
  while ((group = lib.nextPending(state))) {
    const brief = briefPath(ctx, group.n);
    runScript(ctx, "task-brief", [ctx.opts.plan, String(group.n), brief]);
    let retryNote = null;

    while (true) {
      group.attempts += 1;
      group.status = "running";
      saveState(ctx.statePath, state);
      console.log(
        `▸ Group ${group.n}: ${group.name} [${group.model}]` +
          (group.attempts > 1 ? ` (attempt ${group.attempts})` : "")
      );

      const preHead = git(ctx.root, "rev-parse", "HEAD");
      const prompt = lib.buildImplementerPrompt({
        groupN: group.n,
        groupName: group.name,
        briefPath: brief,
        reportPath: reportPath(ctx, group.n),
        workDir: ctx.root,
        constraints: ctx.constraints,
        retryNote,
      });
      const { parsed } = runClaude(ctx, {
        phase: `group-${group.n}`,
        model: group.model,
        prompt,
      });

      let report = "";
      try {
        report = fs.readFileSync(reportPath(ctx, group.n), "utf8");
      } catch {
        report = "";
      }
      const status = lib.parseReportStatus(report) ||
        lib.parseReportStatus(parsed.result);
      const newCommits = git(
        ctx.root,
        "rev-list",
        "--oneline",
        `${preHead}..HEAD`
      );
      const commitLines = newCommits ? newCommits.split("\n") : [];

      if (status === "BLOCKED" || status === "NEEDS_CONTEXT") {
        group.status = "blocked";
        saveState(ctx.statePath, state);
        console.error(`⏸ Group ${group.n} reported ${status}.`);
        console.error(`  Report: ${reportPath(ctx, group.n)}`);
        console.error(
          "  Resolve, set the group's status to \"pending\" in " +
            `${ctx.statePath}, and re-run with --resume.`
        );
        process.exit(2);
      }

      const done = status === "DONE" || status === "DONE_WITH_CONCERNS";
      if (done && commitLines.length > 0) {
        group.status = "completed";
        group.commits = commitLines.map((l) => l.split(" ")[0]);
        saveState(ctx.statePath, state);
        appendLedger(
          ctx,
          `Group ${group.n}: complete (commits ${group.commits[
            group.commits.length - 1
          ]}..${group.commits[0]}, sdd-loop headless, no group review — final nets)`
        );
        if (status === "DONE_WITH_CONCERNS") {
          console.log(
            `⚠ Group ${group.n} DONE_WITH_CONCERNS — see ${reportPath(ctx, group.n)}`
          );
        }
        console.log(`✓ Group ${group.n} complete (${commitLines.length} commit(s))`);
        break;
      }

      const why = done
        ? "reported DONE but created no commits"
        : status
          ? `unexpected status ${status}`
          : "wrote no parseable Status line";
      if (group.attempts >= lib.MAX_ATTEMPTS) {
        group.status = "error";
        saveState(ctx.statePath, state);
        die(
          `Group ${group.n} failed after ${group.attempts} attempts: ${why}`,
          1
        );
      }
      retryNote = `${why}. Read your previous report at ${reportPath(ctx, group.n)} and the current git log, then complete the remaining work.`;
      console.log(`↻ Group ${group.n}: retrying — ${why}`);
    }
  }
}

function main() {
  const opts = parseArgs(process.argv.slice(2));
  if (opts.help) return usage();
  if (opts.error) {
    console.error(`sdd-loop: ${opts.error}`);
    usage();
    process.exit(1);
  }

  let root;
  try {
    root = git(process.cwd(), "rev-parse", "--show-toplevel");
  } catch {
    return die("not inside a git repository", 1);
  }
  opts.plan = path.resolve(opts.plan);
  if (!fs.existsSync(opts.plan)) return die(`no such plan: ${opts.plan}`, 1);

  const planText = fs.readFileSync(opts.plan, "utf8");
  const groups = lib.parsePlanGroups(planText);
  if (groups.length === 0) {
    return die(
      "plan has no '### Group N' headings — tiny plans run inline in-session, not via sdd-loop",
      2
    );
  }
  const constraints = lib.extractGlobalConstraints(planText);
  const workspace = runScript({ root }, "sdd-workspace", []);
  const statePath = path.join(workspace, "loop-state.json");

  if (opts.dryRun) {
    console.log(`plan: ${opts.plan}`);
    for (const g of groups) {
      console.log(`  Group ${g.n}: ${g.name} [${g.model || opts.model}]`);
    }
    console.log(`state: ${statePath}`);
    return;
  }

  let state;
  if (fs.existsSync(statePath)) {
    if (!opts.resume) {
      return die(
        `${statePath} exists — pass --resume to continue, or delete it to start over`,
        1
      );
    }
    try {
      state = JSON.parse(fs.readFileSync(statePath, "utf8"));
    } catch {
      return die(
        `${statePath} is corrupt — recover from the ledger and git log, then delete it`,
        1
      );
    }
    for (const g of state.groups) {
      if (g.status === "running" || g.status === "blocked" || g.status === "error") {
        g.status = "pending";
        g.attempts = 0; // a resume is a fresh chance — the human changed something
      }
    }
  } else {
    state = lib.initState({
      plan: opts.plan,
      branch: git(root, "rev-parse", "--abbrev-ref", "HEAD"),
      mergeBase: git(root, "rev-parse", "HEAD"),
      groups,
      defaultModel: opts.model,
    });
  }

  const ctx = { root, opts, state, statePath, workspace, constraints };
  saveState(statePath, state);
  runGroups(ctx);
  runFinalReview(ctx);
  console.log("✓ sdd-loop complete — plan implemented and review approved.");
  console.log("  Hand back to an interactive session for finishing-a-development-branch.");
}

main();
