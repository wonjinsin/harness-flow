#!/usr/bin/env node
"use strict";

// plan-audit — deterministic completeness gate for an implementation plan.
// Checks that every file a plan task declares (Create/Modify/Test) exists in
// the working tree. With --base, also checks that every declared file changed
// since implementation began and that the branch has at least one
// implementation commit per task. Catches the measured worst-case: silently
// dropping tasks and self-reporting success
// (design/2026-07-18-external-loop-retrospective.md).
//
// Usage: plan-audit PLAN_FILE [--base REF]
// Exit: 0 complete, 1 missing deliverables / commit shortfall, 2 usage error.

const fs = require("node:fs");
const path = require("node:path");
const { spawnSync } = require("node:child_process");
const { parsePlanFiles } = require("./lib/plan-lib.js");

function die(msg) {
  console.error(`plan-audit: ${msg}`);
  process.exit(2);
}

function main() {
  const argv = process.argv.slice(2);
  let plan = null;
  let base = null;
  for (let i = 0; i < argv.length; i++) {
    if (argv[i] === "--base") base = argv[++i];
    else if (!plan && !argv[i].startsWith("--")) plan = argv[i];
    else die(`unknown argument: ${argv[i]}`);
  }
  if (!plan) die("usage: plan-audit PLAN_FILE [--base REF]");
  if (!fs.existsSync(plan)) die(`no such plan: ${plan}`);

  const rootProc = spawnSync("git", ["rev-parse", "--show-toplevel"], {
    encoding: "utf8",
  });
  const root = rootProc.status === 0 ? rootProc.stdout.trim() : process.cwd();

  const tasks = parsePlanFiles(fs.readFileSync(plan, "utf8"));
  if (tasks.length === 0) die(`no tasks with Files: declarations in ${plan}`);

  let failed = false;
  for (const t of tasks) {
    const missing = t.files
      .map((f) => f.path)
      .filter((p) => !fs.existsSync(path.join(root, p)));
    if (missing.length) {
      failed = true;
      console.log(`Task ${t.task}: MISSING ${missing.join(", ")}`);
    } else {
      console.log(`Task ${t.task}: OK`);
    }
  }

  if (base) {
    const diff = spawnSync(
      "git",
      ["diff", "--name-only", `${base}..HEAD`, "--"],
      { encoding: "utf8", cwd: root }
    );
    if (diff.status !== 0) die(`bad --base ref: ${base}`);
    const changed = new Set(diff.stdout.split("\n").filter(Boolean));
    for (const t of tasks) {
      const unchanged = t.files
        .map((f) => f.path)
        .filter((p) => !changed.has(p));
      if (unchanged.length) {
        failed = true;
        console.log(`Task ${t.task}: UNCHANGED ${unchanged.join(", ")}`);
      }
    }

    const count = spawnSync(
      "git",
      ["rev-list", "--count", `${base}..HEAD`],
      { encoding: "utf8", cwd: root }
    );
    if (count.status !== 0) die(`bad --base ref: ${base}`);
    const commits = Number(count.stdout.trim());
    if (commits < tasks.length) {
      failed = true;
      console.log(`commits ${commits} < tasks ${tasks.length}`);
    }
  }

  process.exit(failed ? 1 : 0);
}

main();
