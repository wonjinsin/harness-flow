#!/usr/bin/env bash
# Deterministic placeholder guard for dispatch-time group briefs.
# A brief the controller authors must contain real content — this script
# rejects the placeholder patterns writing-plans used to forbid in plan
# documents, so the guard survives the plan's demotion to execution state.
#
# Usage: brief-check BRIEF_FILE
# Exit: 0 pass / 1 findings (stderr: "line N: reason") / 2 usage error.
set -euo pipefail

if [ $# -ne 1 ]; then
  echo "usage: brief-check BRIEF_FILE" >&2
  exit 2
fi

brief=$1
[ -f "$brief" ] || { echo "no such brief file: $brief" >&2; exit 2; }

# One fence-aware pass. Fences may be indented (list nesting) and use 3+
# backticks; a fence closes only on a run of backticks at least as long as
# its opener with nothing but whitespace after (CommonMark's length rule) —
# so an inner ``` inside a ````-fenced block stays fence content. All three
# checks (placeholder scan, balance, fence presence) share this scanner;
# a naive /^```/ toggle mis-reads both indented and nested fences.
findings=$(awk '
  function ticklen(line,   t) {
    t = line
    sub(/^[ \t]*/, "", t)
    if (t !~ /^```/) return 0
    match(t, /^`+/)
    return RLENGTH
  }
  {
    n = ticklen($0)
    if (infence) {
      t = $0
      sub(/^[ \t]*/, "", t)
      if (n >= openlen && t ~ /^`+[ \t]*$/) infence = 0
      next
    }
    if (n >= 3) { infence = 1; openlen = n; fences++; next }
    raw = $0
    low = tolower($0)
    if (raw ~ /(^|[^[:alnum:]])TODO([^[:alnum:]]|$)/ ||
        low ~ /(^|[^[:alnum:]])tbd([^[:alnum:]]|$)/ ||
        low ~ /implement later|fill in|appropriate error handling|add validation|handle edge cases|similar to (task|group)/)
      printf "line %d: placeholder: %s\n", NR, $0
  }
  END {
    if (infence) print "unbalanced code fences in brief"
    if (fences == 0) print "no code fence in brief — step code blocks are required"
  }
' "$brief")

if [ -n "$findings" ]; then
  printf "%s\n" "$findings" >&2
  exit 1
fi
